% Defines a set of commands to write sections, subsections and subsubsections with shade
%
% Examples with label
% \ShadedSection[sec:test]{Name}
% \ShadedSubection[subsec:test]{Name}
% \ShadedSubsubection[subsubsec:test]{Name}
%
% Examples without label
% \ShadedSection{Name}
% \ShadedSubection{Name}
% \ShadedSubsubection{Name}

\NewDocumentCommand{\ShadedSection}{O{}m}{\IfNoValueTF{#1}{\DarkShadeText{\section{#2}}}{\DarkShadeText{\section{#2}\label{#1}}}}

\NewDocumentCommand{\ShadedSubsection}{O{}m}{\IfNoValueTF{#1}{\MediumShadeText{\subsection{#2}}}{\MediumShadeText{\subsection{#2}\label{#1}}}}

\NewDocumentCommand{\ShadedSubsubsection}{O{}m}{\IfNoValueTF{#1}{\LightShadeText{\subsubsection{#2}}}{\LightShadeText{\subsubsection{#2}\label{#1}}}}

