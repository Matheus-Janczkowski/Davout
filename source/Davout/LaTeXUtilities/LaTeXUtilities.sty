% Command for defining the code block style    

\definecolor{CodeLightGray}{gray}{0.95}
\definecolor{CodeBarColor}{rgb}{0.8,0.8,0.8}  

\renewcommand{\lstlistingname}{Code}

\lstdefinestyle{ffcode}{
  backgroundcolor=\color{CodeLightGray},
  basicstyle=\ttfamily\footnotesize,
  frame=single,
  rulecolor=\color{CodeBarColor},
  xleftmargin=2em,
  framexleftmargin=1.5em,
  numbers=left,
  numberstyle=\tiny\color{gray},
  numbersep=0.5em,
  breaklines=true,
  tabsize=2,
  columns=fullflexible,
  name=Code,
  captionpos=b
}

% Command for creating a code block

\lstnewenvironment{CodeBlock}[1][]{
\lstset{style=ffcode,#1}
}{}

% Command for creating a block of code with caption and, optionally, a
% label
%
% Example with label
% \begin{CodeBlockWithCaption}[lst:code]{Caption}
% bla bla bla
% \end{CodeBlockWithCaption}
%
% Example without label
% \begin{CodeBlockWithCaption}{Caption}
% bla bla bla
% \end{CodeBlockWithCaption}

\lstnewenvironment{CodeBlockWithCaption}[2][]{
\ifstrempty{#1}
{\lstset{style=ffcode,caption={#2}}}
{\lstset{style=ffcode,caption={#2},label={#1}}}
}{}

