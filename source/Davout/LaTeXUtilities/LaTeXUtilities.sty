% Command for making a generic operator with lower and upper text, like
% U_{j=1}^{k}. The arguments are: the letter to symbolize the operator,
% the lower limit, and the upper limit

\newcommand{\GenericOperator}[3]{\mathop{\mathchoice{\raisebox{-0.9ex}{%
\scalebox{1.9}{$\displaystyle #1$}}}% displaystyle
{\raisebox{-0.7ex}{\scalebox{1.4}{$\textstyle #1$}}}% textstyle
{\raisebox{-0.1ex}{\scalebox{1.3}{$\scriptstyle #1$}}}% scriptstyle
{\raisebox{0ex}{\scalebox{1.0}{$\scriptscriptstyle #1$}}}% scriptscriptstyle
}\limits_{#2}^{#3}}

