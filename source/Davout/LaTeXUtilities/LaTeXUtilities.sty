% Commands to build an enumerating environment where the items are alpha-
% betically sorted.
%
% Usage example:
% \begin{AlphabeticalEnumerate}
% \sortitem{Banana}
% \sortitem{Apple}
% \sortitem{Cherry}
% \end{AlphabeticalEnumerate}

\newcommand{\sortitem}[1]{%
  \DTLnewrow{list}% Create a new entry
  \DTLnewdbentry{list}{description}{#1}% Add entry as description
}

\newenvironment{AlphabeticalEnumerate}{%
  \DTLifdbexists{list}{\DTLcleardb{list}}{\DTLnewdb{list}}% Create new/discard old list
}{%
  \DTLsort{description}{list}% Sort list
  \begin{enumerate}%
    \DTLforeach*{list}{\theDesc=description}{%
      \item \theDesc}% Print each item
  \end{enumerate}%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%                             Word counter                             %
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Defines an environment for counting words within a text excerpt.
% Usage example:
% \begin{TextWordCounterWithLimit}{Abstract}{150}
% Physics-informed neural networks combine machine learning
% with physical laws to solve partial differential equations.
% \end{TextWordCounter}
% 
% or
%
% \begin{TextWordCounter}{Abstract}
% Physics-informed neural networks combine machine learning
% with physical laws to solve partial differential equations.
% \end{TextWordCounter}

% Counter for words

\newcounter{wordcount}

% Count words using xstring
\newcommand{\countwords}[1]{%
\setcounter{wordcount}{0}%
\StrCount{#1}{ }[\tempcount]% count spaces
\addtocounter{wordcount}{\tempcount}%
\stepcounter{wordcount}% add 1 for last word
}

% Environment to type in the text and to put the header with the counter
% and the limit of words

\NewEnviron{TextWordCounterWithLimit}[2]{\countwords{\BODY}\par\bigskip
\noindent
\begin{minipage}{\linewidth} % forces the header to stay in the same page
\hrule height 0.5pt % Top bar
\vskip 1pt % Tiny vertical space
\noindent\makebox[\linewidth][l]{\textbf{#1 (\thewordcount/#2 words)}} % Title centered
\vskip 1pt % Tiny vertical space
\hrule height 0.5pt % Bottom bar
\end{minipage}
\par\smallskip\noindent\BODY}

% Environment to type in the text and to put the header with the counter
% without any limits

\NewEnviron{TextWordCounter}[1]{\countwords{\BODY}\par\bigskip
\noindent
\begin{minipage}{\linewidth} % forces the header to stay in the same page
\hrule height 0.5pt % Top bar
\vskip 1pt % Tiny vertical space
\noindent\makebox[\linewidth][l]{\textbf{#1 (\thewordcount$\;$words)}} % Title centered
\vskip 1pt % Tiny vertical space
\hrule height 0.5pt % Bottom bar
\end{minipage}
\par\smallskip\noindent\BODY}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%                           Character counter                          %
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Defines an environment for counting characters within a text excerpt.
% Usage example:
% \begin{TextCharacterCounterWithLimit}{Abstract}{150}
% Physics-informed neural networks combine machine learning
% with physical laws to solve partial differential equations.
% \end{TextCharacterCounterWithLimit}
% 
% or
%
% \begin{TextCharacterCounter}{Abstract}
% Physics-informed neural networks combine machine learning
% with physical laws to solve partial differential equations.
% \end{TextCharacterCounter}

% Counter for characters

\newcounter{charcount}

% Count characters using xstring

\newcommand{\countchars}[1]{%
\setcounter{charcount}{0}%
\StrLen{#1}[\tempcount]% counts all characters including spaces
\setcounter{charcount}{\tempcount}%
}

% Environment to type in the text and to put the header with the counter
% and the limit of characters

\NewEnviron{TextCharacterCounterWithLimit}[2]{\countchars{\BODY}\par\bigskip
\noindent
\begin{minipage}{\linewidth} % forces the header to stay in the same page
\hrule height 0.5pt % Top bar
\vskip 1pt % Tiny vertical space
\noindent\makebox[\linewidth][l]{\textbf{#1 (\thecharcount/#2 characters)}} % Title centered
\vskip 1pt % Tiny vertical space
\hrule height 0.5pt % Bottom bar
\end{minipage}
\par\smallskip\noindent\BODY}

% Environment to type in the text and to put the header with the counter
% without any limits

\NewEnviron{TextCharacterCounter}[1]{\countchars{\BODY}\par\bigskip
\noindent
\begin{minipage}{\linewidth} % forces the header to stay in the same page
\hrule height 0.5pt % Top bar
\vskip 1pt % Tiny vertical space
\noindent\makebox[\linewidth][l]{\textbf{#1 (\thecharcount$\;$characters)}} % Title centered
\vskip 1pt % Tiny vertical space
\hrule height 0.5pt % Bottom bar
\end{minipage}
\par\smallskip\noindent\BODY}