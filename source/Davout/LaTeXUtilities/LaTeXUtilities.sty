% Command to type the div and Div operators

\newcommand{\SpatialDiv}{\mathrm{div}\;}

\newcommand{\SpatialDivOf}[1]{\mathrm{div}\left(#1\right)}

\newcommand{\MaterialDiv}{\mathrm{Div}\;}

\newcommand{\MaterialDivOf}[1]{\mathrm{Div}\left(#1\right)}

% Command to type the grad and Grad operators

\newcommand{\SpatialGrad}{\mathrm{grad}\;}

\newcommand{\SpatialGradOf}[1]{\mathrm{grad}\left(#1\right)}

\newcommand{\MaterialGrad}{\mathrm{Grad}\;}

\newcommand{\MaterialGradOf}[1]{\mathrm{Grad}\left(#1\right)}

% Macro to put a dot over an expresion, important when there is a dot 
% over another dot

\newcommand*{\DotWithLine}[1]{\accentset{\mbox{\large .}}{#1}}

% Macro to make integral differentials prettier
% Example: \IntegralDif t

\newcommand*\IntegralDif{\mathop{}\!\mathrm{d}}

% Macro to make an integral. The first argument is the integration do-
% main; the second is the integrand; the third, the integration diffe-
% rential

\newcommand{\RegionIntegration}[3]{\int\limits_{#1}#2\IntegralDif#3}

% Macro to make an integral onto a path or a single variable. The first
% argument is the lower integration limit; the second is the upper in-
% tegration limit; the third is the integrand; the fourth, the integra-
% tion differential

\newcommand{\SingleVariableIntegration}[4]{\int_{#1}^{#2}#3\IntegralDif#4}

% Command for partial derivative

\newcommand{\PartialDerivative}[2]{\frac{\partial #1}{\partial #2}}

% Command for total derivative

\newcommand{\TotalDerivative}[2]{\frac{\mathrm{d} #1}{\mathrm{d} #2}}

% Command for creating the vertical bar that evaluates derivatives

\newcommand{\EvaluateBar}[3]{\left.#1\right|_{#2}^{#3}}

